generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

enum Plan {
  FREE
  PRO
}

enum Platform {
  INSTAGRAM
  FACEBOOK
  YOUTUBE
  TIKTOK
}

enum Role {
  USER
  ADMIN
}

enum ScheduleStatus {
  SCHEDULED
  PUBLISHED
  FAILED
  CANCELLED
}

enum SocialPlatform {
  INSTAGRAM
  FACEBOOK
  YOUTUBE
  TIKTOK
}



model User {
  id                   String          @id @default(cuid())
  clerkId              String          @unique
  email                String          @unique
  name                 String?
  imageUrl             String?
  plan                 Plan            @default(FREE)
  role                 Role            @default(USER)
  isActive             Boolean         @default(true)
  stripeCustomerId     String?         @unique
  stripeSubscriptionId String?         @unique
  upgradedToPROAt      DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  usage                Usage[]
  generations          Generation[]
  scheduledPosts       ScheduledPost[]
  socialAccounts       SocialAccount[]
}

model Generation {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic         String
  platform      Platform
  caption       String         @db.Text
  hashtags      String[]
  imageUrl      String?
  imageKitId    String?
  isFlagged     Boolean        @default(false)
  isDeleted     Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  scheduledPost ScheduledPost?
}

model ScheduledPost {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationId  String?        @unique
  generation    Generation?    @relation(fields: [generationId], references: [id], onDelete: SetNull)
  caption       String?        @db.Text
  hashtags      String[]
  imageUrl      String?
  imageUrls     String[]
  platforms     Platform[]
  scheduledFor  DateTime?
  status        ScheduleStatus @default(SCHEDULED)
  publishedAt   DateTime?
  failureReason String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId, scheduledFor])
  @@index([status, scheduledFor])
}

model Usage {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime @default(now()) @db.Date
  captionCount  Int      @default(0)
  imageCount    Int      @default(0)
  postCount     Int      @default(0)
  scheduleCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, date])
}

model PlanLimit {
  id            String   @id @default(cuid())
  plan          Plan     @unique
  dailyCaptions Int
  dailyImages   Int
  platforms     String[]
}

model SocialAccount {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform         SocialPlatform
  accessToken      String         @db.Text
  refreshToken     String?        @db.Text
  expiresAt        DateTime?
  accountId        String?
  accountName      String?
  zernioProfileId  String?        // Zernio profile ID for this social account
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([userId, platform])
}

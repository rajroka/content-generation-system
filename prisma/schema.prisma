generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

enum Plan {
  FREE
  PRO
}

enum Platform {
  INSTAGRAM
  FACEBOOK
  TWITTER
  LINKEDIN
  YOUTUBE
}

enum Role {
  USER
  ADMIN
}

enum ScheduleStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
  CANCELLED
}

enum SocialPlatform {
  INSTAGRAM
  FACEBOOK
  TWITTER
  YOUTUBE
  LINKEDIN
}



model User {
  id                   String          @id @default(cuid())
  clerkId              String          @unique
  email                String          @unique
  name                 String?
  imageUrl             String?
  plan                 Plan            @default(FREE)
  role                 Role            @default(USER)
  isActive             Boolean         @default(true)
  stripeCustomerId     String?         @unique
  stripeSubscriptionId String?         @unique
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  usage                Usage[]
  generations          Generation[]
  scheduledPosts       ScheduledPost[]
  socialAccounts       SocialAccount[]
  brandVoice           BrandVoice?
}

model Generation {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic         String
  platform      Platform
  caption       String         @db.Text
  hashtags      String[]
  imageUrl      String?
  imageKitId    String?
  isFlagged     Boolean        @default(false)
  isDeleted     Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  scheduledPost ScheduledPost?
}

model ScheduledPost {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationId  String?        @unique
  generation    Generation?    @relation(fields: [generationId], references: [id], onDelete: SetNull)
  caption       String?        @db.Text
  hashtags      String[]
  imageUrl      String?
  imageUrls     String[]
  platforms     Platform[]
  scheduledFor  DateTime?
  status        ScheduleStatus @default(SCHEDULED)
  publishedAt   DateTime?
  failureReason String?
  zernioPostId  String?        // Zernio post _id for status sync
  retryCount    Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId, scheduledFor])
  @@index([status, scheduledFor])
}

model Usage {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime @default(now()) @db.Date
  captionCount  Int      @default(0)
  imageCount    Int      @default(0)
  postCount     Int      @default(0)
  scheduleCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, date])
}

model PlanLimit {
  id            String   @id @default(cuid())
  plan          Plan     @unique
  dailyCaptions Int
  dailyImages   Int
  platforms     String[]
}

model SocialAccount {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform     SocialPlatform
  accessToken  String         @db.Text
  refreshToken String?        @db.Text
  expiresAt    DateTime?
  accountId    String?
  accountName  String?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([userId, platform])
}

model BrandVoice {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tone        String   @default("CASUAL")   // CASUAL | PROFESSIONAL | INSPIRATIONAL | HUMOROUS
  style       String?  @db.Text             // Free-text style notes e.g. "always use emojis, never exclamation marks"
  keywords    String[] @default([])         // Brand keywords to include
  avoidWords  String[] @default([])         // Words to avoid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}